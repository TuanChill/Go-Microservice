ENV=dev

# API
PORT=8000
HOST=localhost
PORT_FRONTEND=http://localhost:3000
RANDOM_PASSWORD=replace-with-generated-secret
CSRF_TOKEN=replace-with-generated-secret

# PostgreSQL
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_PORT_MAPPING=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=

# RabbitMQ
RABBIT_USER=app_user
RABBIT_PASSWORD=replace-with-local-password
RABBIT_URL=amqp://app_user:replace-with-local-password@rabbitmq:5672/

# Optional AWS adapters
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
